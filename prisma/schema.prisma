// CareerOS AI — Scalable database schema
// SQLite-compatible (no native list types; JSON stored as String)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  headline  String?
  role      String   @default("user") // user | admin
  plan      String   @default("free") // free | pro | premium | enterprise
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes         Resume[]
  coverLetters    CoverLetter[]
  interviews      Interview[]
  coachSessions   CoachSession[]
  jobs            Job[]
  skillProfiles   SkillProfile[]
  aiUsages        AiUsage[]
  notifications   Notification[]
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  title      String
  template   String   @default("modern") // modern | executive | creative | ats | technical | academic | minimal
  accent     String   @default("emerald")
  font       String   @default("inter")
  spacing    String   @default("normal")
  data       String   // JSON: { contact, summary, experience[], education[], skills[], projects[], certifications[], customSections[] }
  atsScore   Int?
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  coverLetters CoverLetter[]
  @@index([userId])
}

model CoverLetter {
  id         String   @id @default(cuid())
  userId     String
  resumeId   String?
  type       String   @default("cover") // cover | followup | thankyou | networking | referral
  company    String?
  role       String?
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume     Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  @@index([userId])
}

model Interview {
  id         String   @id @default(cuid())
  userId     String
  type       String   // technical | hr | behavioral | industry
  role       String?
  company    String?
  status     String   @default("active") // active | completed
  messages   String   // JSON: [{role, content, rating?, feedback?}]
  score      Int?
  summary    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CoachSession {
  id         String   @id @default(cuid())
  userId     String
  title      String
  focus      String   // career-planning | promotion | salary | skills | industry | pivot
  messages   String   // JSON: [{role, content}]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Job {
  id          String   @id @default(cuid())
  userId      String
  company     String
  role        String
  location    String?
  salary      String?
  url         String?
  status      String   @default("wishlist") // wishlist | applied | screening | interview | offer | rejected | accepted
  priority    String   @default("medium") // low | medium | high
  notes       String?
  appliedAt   DateTime?
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([status])
}

model SkillProfile {
  id         String   @id @default(cuid())
  userId     String
  targetRole String
  skills     String   // JSON: [{ name, level, targetLevel }]
  gaps       String?  // JSON: [{ skill, gap, priority }]
  roadmap    String?  // JSON: [{ phase, focus, actions[], courses[] }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model AiUsage {
  id         String   @id @default(cuid())
  userId     String
  feature    String   // resume-enhance | ats-analyze | cover-letter | interview | coach | skills
  tokens     Int      @default(0)
  cost       Float    @default(0)
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
