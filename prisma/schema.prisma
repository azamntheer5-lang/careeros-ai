// CareerOS AI — Local SQLite schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  headline        String?
  passwordHash    String?
  role            String   @default("user") // user | admin | owner | recruiter | creator
  plan            String   @default("free") // free | starter | professional | career_pro | enterprise
  tenantId        String?
  onboarded       Boolean  @default(false)
  credits         Int      @default(50) // AI credit balance
  trialEndsAt     DateTime?
  mfaEnabled      Boolean  @default(false)
  sessionToken    String?
  sessionExpiresAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  resumes         Resume[]
  coverLetters    CoverLetter[]
  interviews      Interview[]
  coachSessions   CoachSession[]
  jobs            Job[]
  skillProfiles   SkillProfile[]
  aiUsages        AiUsage[]
  notifications   Notification[]
  profile         CareerProfile?
  portfolios      Portfolio[]
  brandings       BrandingAnalysis[]
  careerPlans     CareerPlan[]
  companies       Company[]
  contacts        Contact[]
  reminders       Reminder[]
  auditLogs       AuditLog[]
  agentRuns       AgentRun[]
  graphNodes      GraphNode[]
  workflowRuns    WorkflowRun[]
  networkProfile  NetworkProfile?
  posts           Post[]
  mentorProfile   Mentor?
  bookings        Booking[]   @relation("BookingUser")
  tenant          Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subscription    Subscription?
  creditTxns      CreditTransaction[]
  assessments     Assessment[]
  briefings       CareerBriefing[]
  jobPostings     JobPosting[]  @relation("JobPostingEmployer")
  applications    CandidateApplication[]
  templatePubs    Template[]
  creatorContent  CreatorContent[]
  achievements    Achievement[]
}

model CareerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  targetRole      String?
  industry        String?
  seniority       String?  // junior | mid | senior | staff | principal | lead | director | vp | c-suite
  experienceYears Int?
  targetSalary    String?
  currency        String   @default("USD")
  location        String?
  workMode        String?  // remote | hybrid | onsite
  careerGoals     String?  // free text
  timeline        String?  // 3m | 6m | 1y | 2y | 5y
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  brandStatement  String?
  strengths       String?  // JSON string[]
  values          String?  // JSON string[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  title      String
  template   String   @default("modern")
  accent     String   @default("emerald")
  font       String   @default("inter")
  spacing    String   @default("normal")
  careerMode String?  // developer | designer | executive | academic | medical | government | general
  data       String   // JSON: { contact, summary, experience[], ... }
  atsScore   Int?
  aiScore    Int?     // overall AI quality score 0-100
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions   ResumeVersion[]
  coverLetters CoverLetter[]
  @@index([userId])
}

model ResumeVersion {
  id        String   @id @default(cuid())
  resumeId  String
  version   Int
  data      String   // snapshot
  atsScore  Int?
  aiScore   Int?
  note      String?
  createdAt DateTime @default(now())
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  @@index([resumeId])
}

model CoverLetter {
  id         String   @id @default(cuid())
  userId     String
  resumeId   String?
  type       String   @default("cover")
  company    String?
  role       String?
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume     Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  @@index([userId])
}

model Interview {
  id         String   @id @default(cuid())
  userId     String
  type       String   // technical | hr | behavioral | industry
  role       String?
  company    String?
  mode       String   @default("text") // text | voice
  status     String   @default("active") // active | completed
  messages   String   // JSON: [{role, content, rating?, feedback?}]
  score      Int?
  confidence Int?     // voice confidence score
  summary    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CoachSession {
  id         String   @id @default(cuid())
  userId     String
  title      String
  focus      String
  messages   String   // JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Job {
  id          String   @id @default(cuid())
  userId      String
  companyId   String?
  company     String
  role        String
  location    String?
  salary      String?
  url         String?
  status      String   @default("wishlist")
  priority    String   @default("medium")
  notes       String?
  appliedAt   DateTime?
  deadline    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyRef  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([status])
}

model SkillProfile {
  id         String   @id @default(cuid())
  userId     String
  targetRole String
  skills     String   // JSON
  gaps       String?  // JSON
  roadmap    String?  // JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Portfolio {
  id         String   @id @default(cuid())
  userId     String
  slug       String   @unique
  title      String
  tagline    String?
  bio        String?
  theme      String   @default("aurora") // aurora | minimal | bold | dark | paper
  accent     String   @default("emerald")
  sections   String   // JSON: ordered section config
  published  Boolean  @default(false)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model BrandingAnalysis {
  id         String   @id @default(cuid())
  userId     String
  type       String   // linkedin | identity
  headline   String?
  about      String?
  data       String   // JSON analysis payload
  score      Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CareerPlan {
  id              String   @id @default(cuid())
  userId          String
  targetRole      String
  roadmap         String   // JSON phases
  salaryStrategy  String?
  promotionPlan   String?
  marketInsights  String?  // JSON
  readinessScore  Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Company {
  id         String   @id @default(cuid())
  userId     String
  name       String
  domain     String?
  industry   String?
  size       String?  // startup | small | mid | large | enterprise
  stage      String?  // seed | a | b | c | ipo | public
  location   String?
  culture    String?
  notes      String?
  research   String?  // JSON research payload
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs       Job[]
  @@index([userId])
}

model Contact {
  id            String   @id @default(cuid())
  userId        String
  companyId     String?
  name          String
  role          String?
  email         String?
  linkedin      String?
  phone         String?
  type          String   @default("recruiter") // recruiter | hiring_manager | peer | referral | mentor
  notes         String?
  lastContactAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  companyId String?
  title     String
  dueAt     DateTime
  type      String   @default("followup") // followup | interview | deadline | custom
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([dueAt])
}

model AiUsage {
  id         String   @id @default(cuid())
  userId     String
  feature    String
  model      String?  // routed model label
  tokens     Int      @default(0)
  cost       Float    @default(0)
  latencyMs  Int?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      String?  // JSON
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([action])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(true)
  description String?
  rollout     Int      @default(100) // percentage 0-100
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// PHASE 3 — Agent Ecosystem, Knowledge Graph, Automation, Network, Marketplace
// ---------------------------------------------------------------------------

model AgentRun {
  id         String   @id @default(cuid())
  userId     String
  agent      String   // career | resume | job | interview | learning
  status     String   @default("pending") // pending | running | done | error
  trigger    String   @default("manual") // manual | workflow | scheduled
  summary    String?
  actions    String?  // JSON: [{ type, target, result }]
  insights   String?  // JSON: string[]
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, agent])
  @@index([createdAt])
}

model GraphNode {
  id         String   @id @default(cuid())
  userId     String
  kind       String   // experience | skill | project | education | certificate | goal | job | company | interview | achievement
  label      String
  value      String?  // JSON with kind-specific data
  weight     Int      @default(1)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  edgesFrom  GraphEdge[] @relation("EdgeFrom")
  edgesTo    GraphEdge[] @relation("EdgeTo")
  @@index([userId, kind])
  @@unique([userId, kind, label])
}

model GraphEdge {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  rel       String   // uses | worked_at | earned | targets | applied_to | interviewed_at | achieved | requires
  weight    Int      @default(1)
  from      GraphNode @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        GraphNode @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)
  @@index([fromId])
  @@index([toId])
}

model WorkflowRun {
  id         String   @id @default(cuid())
  userId     String
  workflow   String   // new_job_application | new_skill | profile_updated | weekly_review
  trigger    String   // JSON: { type, payload }
  status     String   @default("running") // running | done | error
  steps      String?  // JSON: [{ step, status, result }]
  result     String?  // JSON summary
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])
}

model NetworkProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  slug       String   @unique
  bio        String?
  headline   String?
  tags       String?  // JSON string[]
  visibility String   @default("public") // public | private
  followers  Int      @default(0)
  following  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections Connection[] @relation("ConnectionFollower")
  connectionsTo Connection[] @relation("ConnectionFollowee")
  @@index([slug])
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followeeId  String
  createdAt   DateTime @default(now())
  follower    NetworkProfile @relation("ConnectionFollower", fields: [followerId], references: [id], onDelete: Cascade)
  followee    NetworkProfile @relation("ConnectionFollowee", fields: [followeeId], references: [id], onDelete: Cascade)
  @@unique([followerId, followeeId])
  @@index([followeeId])
}

model Post {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("post") // post | achievement | question | opportunity
  title      String?
  content    String
  tags       String?  // JSON string[]
  likes      Int      @default(0)
  comments   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])
}

model Mentor {
  id            String   @id @default(cuid())
  userId        String   @unique
  slug          String   @unique
  title         String
  expertise     String?  // JSON string[]
  industries    String?  // JSON string[]
  experience    Int?
  rate          Int      @default(0) // per session in cents
  currency      String   @default("USD")
  rating        Float    @default(0)
  sessions      Int      @default(0)
  bio           String?
  availability  String?  // JSON: slots
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[] @relation("BookingMentor")
  @@index([slug])
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  mentorId    String
  type        String   @default("session") // session | resume_review | mock_interview
  topic       String?
  scheduledAt DateTime
  duration    Int      @default(60) // minutes
  status      String   @default("pending") // pending | confirmed | completed | cancelled
  price       Int      @default(0)
  feedback    String?  // JSON: { rating, comment, mentorNotes }
  createdAt   DateTime @default(now())
  user        User     @relation("BookingUser", fields: [userId], references: [id], onDelete: Cascade)
  mentor      Mentor   @relation("BookingMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([mentorId])
  @@index([scheduledAt])
}

model JobMarketInsight {
  id         String   @id @default(cuid())
  userId     String?
  query      String
  data       String   // JSON: { trends, salaries, demand, predictions, companies }
  createdAt  DateTime @default(now())
  @@index([query])
  @@index([createdAt])
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  type        String   // company | university
  domain      String?
  plan        String   @default("enterprise")
  seats       Int      @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     User[]
  employees   Employee[]
  departments Department[]
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  headcount Int      @default(0)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  @@index([tenantId])
}

model Employee {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  name         String
  email        String
  role         String?
  departmentId String?
  level        String?
  skills       String?  // JSON string[]
  goals        String?  // JSON string[]
  growthScore  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([departmentId])
}

model Document {
  id         String   @id @default(cuid())
  userId     String?
  type       String   // resume | certificate | portfolio | id | other
  filename   String
  mimeType   String
  data       String   // base64 content or extracted text
  parsed     String?  // JSON: extracted structured data
  status     String   @default("pending") // pending | parsed | error
  createdAt  DateTime @default(now())
  @@index([userId])
  @@index([type])
}

// ---------------------------------------------------------------------------
// PHASE 4 — SaaS Foundation: Billing, Credits, Assessment, Recruitment,
// Marketplace, Analytics, Security
// ---------------------------------------------------------------------------

model Subscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  plan            String   @default("free") // free | starter | professional | career_pro | enterprise
  status          String   @default("active") // active | trialing | past_due | canceled | expired
  interval        String?  // monthly | annual
  stripeCustomerId String?
  stripeSubId     String?
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd  Boolean @default(false)
  startedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  @@index([userId])
}

model Invoice {
  id              String   @id @default(cuid())
  subscriptionId  String
  userId          String
  amount          Int      // cents
  currency        String   @default("USD")
  status          String   @default("paid") // paid | open | void | uncollectible
  description     String?
  stripeInvoiceId String?
  periodStart     DateTime
  periodEnd       DateTime
  createdAt       DateTime @default(now())
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([subscriptionId])
}

model CreditTransaction {
  id         String   @id @default(cuid())
  userId     String
  amount     Int      // positive = purchase/grant, negative = usage
  reason     String   // purchase | grant | usage | refund | bonus
  feature    String?  // which feature consumed credits
  balance    Int      // running balance after txn
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([createdAt])
}

model Assessment {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("career") // career | personality | skill
  answers    String   // JSON: { experience, skills, goals, industry, salary, personality, ambition }
  result     String?  // JSON: AI-generated career profile
  score      Int?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model CareerBriefing {
  id         String   @id @default(cuid())
  userId     String
  type       String   // daily | weekly
  content    String   // JSON: { summary, priorities, alerts, recommendations, achievements }
  readAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, type])
  @@index([createdAt])
}

model JobPosting {
  id           String   @id @default(cuid())
  employerId   String
  tenantId     String?
  title        String
  company      String
  location     String?
  remote       Boolean  @default(false)
  salary       String?
  type         String   @default("full-time") // full-time | part-time | contract | internship
  description  String
  requirements String?  // JSON string[]
  skills       String?  // JSON string[]
  status       String   @default("open") // open | closed | draft
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  employer     User     @relation("JobPostingEmployer", fields: [employerId], references: [id], onDelete: Cascade)
  applications CandidateApplication[]
  @@index([employerId])
  @@index([status])
}

model CandidateApplication {
  id          String   @id @default(cuid())
  jobPostingId String
  candidateId String
  status      String   @default("submitted") // submitted | reviewed | shortlisted | interview | rejected | hired
  matchScore  Int?
  matchNotes  String?
  coverLetter String?
  createdAt   DateTime @default(now())
  jobPosting  JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  candidate   User     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  @@unique([jobPostingId, candidateId])
  @@index([candidateId])
  @@index([status])
}

model Template {
  id          String   @id @default(cuid())
  creatorId   String
  type        String   // resume | portfolio | cover_letter
  name        String
  description String?
  category    String?  // industry / style category
  preview     String?  // JSON preview config
  config      String   // JSON template config
  price       Int      @default(0) // cents, 0 = free
  downloads   Int      @default(0)
  rating      Float    @default(0)
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@index([type, published])
  @@index([creatorId])
}

model CreatorContent {
  id          String   @id @default(cuid())
  creatorId   String
  type        String   // course | guide | template | coaching_pack
  title       String
  description String?
  content     String   // JSON or markdown
  price       Int      @default(0)
  tags        String?  // JSON string[]
  published   Boolean  @default(false)
  enrollments Int      @default(0)
  rating      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@index([creatorId])
  @@index([type, published])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // resume_created | ats_score | interview_completed | job_applied | skill_learned | streak | milestone
  title       String
  description String?
  value       Int?
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([type])
}

