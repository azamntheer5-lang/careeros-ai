# ===========================================
# CareerOS AI — متغيرات البيئة للإنتاج (Vercel)
# ===========================================
# انسخ هذه القيم إلى Vercel Dashboard > Settings > Environment Variables

# --- قاعدة البيانات (إلزامي) ---
# احصل عليها من Neon.tech أو Vercel Postgres
DATABASE_URL=postgresql://user:password@host:5432/careeros?sslmode=require

# --- المصادقة (إلزامي) ---
# توليد المفتاح: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://your-domain.vercel.app

# --- ذاكرة التخزين المؤقت (اختياري) ---
# احصل عليها من Upstash Redis (مجاني)
REDIS_URL=redis://default:password@host:6379

# --- Stripe للمدفوعات (اختياري للإنتاج الكامل) ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# --- مراقبة الأخطاء (اختياري) ---
SENTRY_DSN=https://xxx@sentry.io/xxx

# --- مفتاح ZAI SDK (مدمج، لا يحتاج إعداد) ---
